---
import { Icon } from "astro-icon/components";

interface Props {
    title: string;
}

const { title } = Astro.props as Props;
---

<div class="hidden h-10 bg-titlebar-bg lg:flex items-stretch px-2 text-sm shrink-0 justify-center gap-2">
    <div class="flex flex-1/3 items-center gap-1">
        <img src="/favicon.png" alt="logo" class="h-8" />
        <h1 class="hidden lg:block text-xl font-semibold">CodeArt.Online - WoofZJ's Blog</h1>
    </div>
    <div class="flex-1/3 flex items-center gap-2 justify-center">
        <div
            class="grow bg-titlebar-title-bg border border-titlebar-border rounded-lg h-7 flex items-center justify-center text-nowrap"
        >
            <span class="text-sm">
                {title} | CodeArt.Online
            </span>
        </div>
    </div>
    <div class="flex flex-1/12 xl:flex-1/3"></div>
</div>
