---
import { Icon } from "astro-icon/components";

interface Props {
    title: string;
    height?: string;
    expanded?: boolean;
}

const { title, height = "flex-1", expanded = true } = Astro.props;
---

<div
    class:list={[
        "sidebar-item",
        "text-sm",
        "overflow-hidden",
        "transition-all",
        "duration-300",
        "ease-in-out",
        "min-h-6",
        { [height]: expanded, "h-6": !expanded },
    ]}
>
    <div
        class="title-bar bg-sidebar-title-bg flex items-center h-6 gap-1 px-2 cursor-pointer select-none"
    >
        <Icon
            name="tabler:chevron-right"
            size="16"
            class:list={[
                "icon",
                "transition-transform",
                { "rotate-90": expanded },
            ]}
        />
        <span>{title}</span>
    </div>
    <div>
        <slot />
    </div>
</div>

<script>
    document.querySelectorAll(".sidebar-item").forEach((element) => {
        const item = element as HTMLElement;
        const titleBar = item.querySelector(".title-bar") as HTMLElement;
        const icon = item.querySelector(".icon") as HTMLElement;
        if (titleBar && icon) {
            titleBar.addEventListener("click", () => {
                const isExpanded = icon.classList.contains("rotate-90");
                if (isExpanded) {
                    item.classList.add("h-6");
                    item.classList.remove(item.dataset.height || "flex-1");
                    icon.classList.remove("rotate-90");
                } else {
                    item.classList.add(item.dataset.height || "flex-1");
                    item.classList.remove("h-6");
                    icon.classList.add("rotate-90");
                }
            });
        }
    });
</script>
