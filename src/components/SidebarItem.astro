---
import { Icon } from "astro-icon/components";

interface Props {
    title: string;
    index: number;
    expanded?: boolean;
}

const { title, index, expanded = true } = Astro.props;
const uuid = crypto.randomUUID();
---

<div
    class:list={[
        "sidebar-item-title-bar",
        "bg-sidebar-title-bg",
        "flex",
        "items-center",
        "h-6",
        "gap-1",
        "px-2",
        "cursor-pointer",
        "select-none",
        "sticky",
        "z-10",
        {
            "top-0": index === 0,
            "top-6": index === 1,
            "top-12": index === 2,
            "top-18": index === 3,
            "top-24": index === 4,
        },
    ]}
    data-uuid={uuid}
>
    <Icon
        name="tabler:chevron-right"
        size="16"
        class:list={[
            "sidebar-item-icon",
            "transition-transform",
            { "rotate-90": expanded },
        ]}
    />
    <span class="text-sm">{title}</span>
</div>
<div
    class:list={[
        "sidebar-item-content",
        "transition-all",
        "duration-300",
        "ease-in-out",
        "overflow-hidden",
        {
            "h-0": !expanded,
            "h-auto": expanded,
        },
    ]}
    data-uuid={uuid}
>
    <slot />
</div>

<script>
    document.querySelectorAll(".sidebar-item-title-bar").forEach((element) => {
        const titleBar = element as HTMLElement;
        const uuid = titleBar.dataset.uuid;
        const content = document.querySelector(
            `.sidebar-item-content[data-uuid="${uuid}"]`,
        ) as HTMLElement;
        const icon = titleBar.querySelector(
            ".sidebar-item-icon",
        ) as HTMLElement;
        if (titleBar && icon && content) {
            titleBar.addEventListener("click", () => {
                const isExpanded = icon.classList.contains("rotate-90");
                if (isExpanded) {
                    icon.classList.remove("rotate-90");
                    content.classList.remove("h-auto");
                    content.classList.add("h-0");
                } else {
                    icon.classList.add("rotate-90");
                    content.classList.remove("h-0");
                    content.classList.add("h-auto");
                }
            });
        }
    });
</script>
